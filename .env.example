# ─── Application ───────────────────────────────────────────────
APP_ENV=development              # development | production
SECRET_KEY=                      # 64-char random hex string (python -c "import secrets; print(secrets.token_hex(32))")
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ──────────────────────────────────────────────────
POSTGRES_HOST=db                 # Docker service name
POSTGRES_PORT=5432
POSTGRES_DB=alvinai
POSTGRES_USER=alvinai
POSTGRES_PASSWORD=               # Strong random password — never commit real value

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0   # Docker service name as host

# ─── MinIO ─────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000        # Docker service name as host
MINIO_ACCESS_KEY=                # MinIO root user (min 3 chars)
MINIO_SECRET_KEY=                # MinIO root password (min 8 chars)
MINIO_BUCKET_DOCUMENTS=documents # Bucket for raw document storage (PDFs, DOCX)
MINIO_BUCKET_MODELS=models       # Bucket for model weights storage
MINIO_BUCKET_BACKUPS=backups     # Bucket for nightly DB backups

# ─── vLLM (Production Inference) ──────────────────────────────
VLLM_BASE_URL=http://vllm_blue:8080/v1  # Active vLLM instance endpoint
VLLM_MODEL_ID=sarfarazflow/alvinai-7b-awq-20250101  # HuggingFace repo ID (versioned by date)
VLLM_GREEN_MODEL_ID=             # Set during blue-green swap only (e.g. sarfarazflow/alvinai-7b-awq-20250201)
VLLM_MODEL_NAME=alvinai-7b-awq  # Model name exposed via vLLM /v1/models endpoint
VLLM_TIMEOUT_SECONDS=30         # Timeout for vLLM inference requests
HF_TOKEN=                        # HuggingFace token — required if model repo is private or gated

# ─── Ollama (Local Dev Only) ──────────────────────────────────
# These are used in docker-compose.override.yml only.
# In production, vLLM blue/green replaces Ollama entirely.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b

# ─── Embeddings ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2 # Self-hosted, CPU, 384-dim, L2-normalised
EMBEDDING_DIM=384                # Must match the embedding model output dimension

# ─── RAG ───────────────────────────────────────────────────────
RAG_TOP_K=5                      # Number of chunks returned after reranking
RAG_SIMILARITY_THRESHOLD=0.72    # Below this score → "not found" response
RAG_COMPLIANCE_SIMILARITY_THRESHOLD=0.80  # Stricter threshold for compliance namespace
RAG_CACHE_TTL=3600               # Redis cache TTL in seconds (1 hour)

# ─── Authentication ────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15   # JWT access token lifetime
REFRESH_TOKEN_EXPIRE_DAYS=7      # JWT refresh token lifetime (httpOnly cookie)

# ─── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=                       # SMTP server hostname
SMTP_PORT=587                    # SMTP port (587 for STARTTLS)
SMTP_USER=                       # SMTP authentication username
SMTP_PASS=                       # SMTP authentication password
EMAIL_FROM=noreply@autocompany.com  # Sender address for system emails
COMPLIANCE_ALERT_EMAIL=legal@autocompany.com  # Alert recipient for compliance issues

# ─── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=                      # Optional — Sentry error tracking DSN
WANDB_API_KEY=                   # Optional — Weights & Biases (RunPod training only)
