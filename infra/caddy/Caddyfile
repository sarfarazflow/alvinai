:80 {
	# WebSocket upgrade
	@websocket {
		path /ws/*
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @websocket backend:8000

	# API routes -> FastAPI backend
	handle /api/* {
		reverse_proxy backend:8000
	}

	# All other routes -> SvelteKit frontend
	handle {
		reverse_proxy frontend:3000
	}
}
